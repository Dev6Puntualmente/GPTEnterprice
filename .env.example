# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Opción A: URL completa
# DATABASE_URL=postgresql://usuario:password@localhost:5434/SalesCloserAI

# Opción B: variables separadas (Next.js y Prisma las combinan automáticamente)
DB_HOST=localhost
DB_PORT=5434
DB_USER=SalesCloser
DB_PASSWORD=
DB_NAME=SalesCloserAI
# Schema aislado — no toca tablas de SalesCloser en public
DB_SCHEMA=gptenterprice

# ── Next.js / Auth ──────────────────────────────────────────────────────────
# Puerto fijo: npm run dev → 3001 (no comparte cookies con Qontrol en 3004)
AUTH_SECRET=genera-un-secreto-largo-aqui
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001
AGENT_API_URL=http://127.0.0.1:8101

# Admin demo (seed)
SEED_ADMIN_DOCUMENT=1000000001
SEED_ADMIN_EMAIL=admin@gptenterprice.local
SEED_ADMIN_PASSWORD=Admin1234!

# ── Hugging Face (requerido para VLLM) ──────────────────────────────────────
HF_TOKEN=

# ── VLLM — Phi 3.5 (chat + tools) ─────────────────────────────────────────
VLLM_URL=http://localhost:8002/v1
VLLM_MODEL=Phi-3.5-mini-instruct

# ── FastAPI Agent ───────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://127.0.0.1:8101
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
STORAGE_DIR=storage
MAX_TOOL_ITERATIONS=5
# false = chat sin function-calling (vLLM remoto sin --enable-auto-tool-choice)
VLLM_TOOLS_ENABLED=false
