# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Opción A: URL completa
# DATABASE_URL=postgresql://usuario:password@localhost:5434/SalesCloserAI

# Opción B: variables separadas (Next.js y Prisma las combinan automáticamente)
DB_HOST=localhost
DB_PORT=5434
DB_USER=SalesCloser
DB_PASSWORD=
DB_NAME=SalesCloserAI
# Schema aislado — no toca tablas de SalesCloser en public
DB_SCHEMA=gptenterprice

# ── Next.js / Auth ──────────────────────────────────────────────────────────
AUTH_SECRET=genera-un-secreto-largo-aqui
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
AGENT_API_URL=http://localhost:8100

# Admin demo (seed)
SEED_ADMIN_EMAIL=admin@gptenterprice.local
SEED_ADMIN_PASSWORD=Admin1234!

# ── VLLM — Qwen 7B (cerebro / tools) ───────────────────────────────────────
VLLM_SMART_URL=http://localhost:8001/v1
VLLM_SMART_MODEL=Qwen2.5-7B-Instruct

# ── VLLM — Phi 3.5 (chat rápido) ───────────────────────────────────────────
VLLM_FAST_URL=http://localhost:8002/v1
VLLM_FAST_MODEL=Phi-3.5-mini-instruct

# ── FastAPI Agent ───────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8100
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
STORAGE_DIR=storage
MAX_TOOL_ITERATIONS=5
