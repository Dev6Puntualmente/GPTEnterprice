{
  "name": "gptenterprice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma generate && npx tsx prisma/seed.ts",
    "db:setup": "npx prisma migrate dev --name init && npx tsx prisma/seed.ts",
    "backend:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "backend:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-backend.ps1",
    "backend:start:reload": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-backend.ps1 -Reload"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.23.24",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
