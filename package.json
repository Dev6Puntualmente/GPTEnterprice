{
  "name": "gptenterprice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-database-url.mjs \"npx prisma generate\" && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "node scripts/with-database-url.mjs \"npx prisma generate\"",
    "db:push": "node scripts/with-database-url.mjs \"npx prisma db push\"",
    "db:migrate": "node scripts/with-database-url.mjs \"npx prisma migrate dev\"",
    "db:seed": "node scripts/with-database-url.mjs \"npx prisma generate\" && node scripts/with-database-url.mjs \"npx tsx prisma/seed.ts\"",
    "db:setup": "node scripts/with-database-url.mjs \"npx prisma migrate dev --name init\" && node scripts/with-database-url.mjs \"npx tsx prisma/seed.ts\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
